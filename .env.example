# Optional override for the basemap PMTiles URL. Default is a same-origin
# fetch from /data/basemap.pmtiles, which is what the Netlify build serves
# after running `npm run prepare-basemap`. Override this locally or in a
# different deploy target (R2, CloudFront, etc.) to point at an externally
# hosted archive — see src/lib/map-style.ts.
#
# VITE_PMTILES_URL=https://example.com/basemap.pmtiles
